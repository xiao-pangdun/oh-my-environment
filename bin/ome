#!/usr/bin/env zsh
# ome — oh-my-environment CLI

set -euo pipefail

OME_HOME="${OME_HOME:-$HOME/.oh-my-environment}"
source "$OME_HOME/core/libs/log.zsh"
source "$OME_HOME/core/libs/path.zsh"

# --- Commands ---

ome_cmd_install() {
  ome_info "Installing configs..."

  local loader="${OME_LOADER:-zinit}"
  local loader_zshrc="$OME_HOME/loaders/$loader/.zshrc"

  # Link loader .zshrc → ~/.zshrc
  if [[ -f "$loader_zshrc" ]]; then
    ome_symlink "$loader_zshrc" "$HOME/.zshrc"
  else
    ome_warn "No .zshrc template for loader: $loader"
  fi

  # Run module install.zsh files
  local install_file
  for install_file in "$OME_HOME"/core/modules/*/install.zsh(N); do
    source "$install_file"
  done

  ome_info "Install complete."
}

ome_cmd_update() {
  ome_info "Updating oh-my-environment..."

  # Update ome itself
  if git -C "$OME_HOME" pull --rebase; then
    ome_info "Repository updated."
  else
    ome_error "Failed to update repository."
    return 1
  fi

  # Loader-specific plugin updates
  local loader="${OME_LOADER:-zinit}"
  case "$loader" in
    zinit)
      if (( ${+functions[zinit]} )); then
        ome_info "Updating zinit plugins..."
        zinit update --all
      else
        ome_warn "zinit not loaded, skipping plugin update."
      fi
      ;;
    plain)
      ome_info "Updating plain plugins..."
      local plugin_dir
      for plugin_dir in "$OME_HOME"/.plugins/*(N/); do
        git -C "$plugin_dir" pull --rebase 2>/dev/null || true
      done
      ;;
    oh-my-zsh)
      ome_info "oh-my-zsh manages its own plugin updates."
      ;;
  esac

  # Re-install configs
  ome_cmd_install

  ome_info "Update complete."
}

ome_cmd_doctor() {
  local issues=0

  ome_info "Running diagnostics..."

  # Check OME_HOME
  if [[ ! -d "$OME_HOME" ]]; then
    ome_error "OME_HOME not found: $OME_HOME"
    (( issues++ ))
  fi

  # Check .zshrc symlink
  if [[ -L "$HOME/.zshrc" ]]; then
    local target="$(readlink "$HOME/.zshrc")"
    if [[ "$target" == *oh-my-environment* ]]; then
      ome_info ".zshrc → $target"
    else
      ome_warn ".zshrc points to: $target (not managed by ome)"
      (( issues++ ))
    fi
  else
    ome_warn ".zshrc is not a symlink"
    (( issues++ ))
  fi

  # Check loader
  local loader="${OME_LOADER:-zinit}"
  if [[ ! -f "$OME_HOME/loaders/$loader/loader.zsh" ]]; then
    ome_error "Loader not found: $loader"
    (( issues++ ))
  else
    ome_info "Loader: $loader"
  fi

  # Check required tools
  local tool
  for tool in git zsh; do
    if (( $+commands[$tool] )); then
      ome_info "$tool: $(command $tool --version 2>&1 | head -1)"
    else
      ome_error "$tool: not found"
      (( issues++ ))
    fi
  done

  # Check optional tools used by modules
  for tool in starship fnm uv sdk; do
    if (( $+commands[$tool] )); then
      ome_info "$tool: found"
    else
      ome_warn "$tool: not found (optional)"
    fi
  done

  # Check module install targets
  local install_file
  for install_file in "$OME_HOME"/core/modules/*/install.zsh(N); do
    local mod_name="${install_file:h:t}"
    ome_info "Module with install: $mod_name"
  done

  if (( issues == 0 )); then
    ome_info "No issues found."
  else
    ome_warn "$issues issue(s) found."
  fi
}

# --- Dispatch ---

case "${1:-}" in
  install) ome_cmd_install ;;
  update)  ome_cmd_update ;;
  doctor)  ome_cmd_doctor ;;
  *)
    echo "Usage: ome <command>"
    echo ""
    echo "Commands:"
    echo "  install           Install configs (.zshrc, module symlinks)"
    echo "  update            Update ome + plugins + re-install configs"
    echo "  doctor            Diagnose issues"
    ;;
esac
