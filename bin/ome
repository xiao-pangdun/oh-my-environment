#!/usr/bin/env zsh
# ome — oh-my-environment CLI (tool management)

set -euo pipefail

OME_HOME="${OME_HOME:-$HOME/.oh-my-environment}"
source "$OME_HOME/lib/log.zsh"
source "$OME_HOME/lib/path.zsh"

# --- Helpers ---

# Read disabled modules from .omerc
_ome_disabled_modules() {
  local disabled=()
  if [[ -f "$HOME/.omerc" ]]; then
    source "$HOME/.omerc"
    zstyle -a ':ome:modules' disabled disabled 2>/dev/null
  fi
  echo "${disabled[@]}"
}

# --- Commands ---

ome_cmd_install() {
  ome_info "Installing oh-my-environment..."

  local disabled=($(_ome_disabled_modules))
  local custom_dir="$OME_HOME/.custom"
  mkdir -p "$custom_dir/plugins"

  # Clean old module symlinks from .custom/
  local existing
  for existing in "$custom_dir"/*.zsh(N); do
    if [[ -L "$existing" ]]; then
      local link_target="$(readlink "$existing")"
      if [[ "$link_target" == *"$OME_HOME/modules"* ]]; then
        rm -f "$existing"
      fi
    fi
  done

  # Symlink module init.zsh files into .custom/
  local mod_dir mod_name
  for mod_dir in "$OME_HOME"/modules/*(N/); do
    mod_name="${mod_dir:t}"

    # Skip disabled modules
    if (( ${disabled[(Ie)$mod_name]} )); then
      ome_info "skipped (disabled): $mod_name"
      continue
    fi

    # Only symlink if module has init.zsh
    if [[ -f "$mod_dir/init.zsh" ]]; then
      ln -sf "$mod_dir/init.zsh" "$custom_dir/$mod_name.zsh"
      ome_info "enabled: $mod_name"
    fi
  done

  # Run module install.zsh files
  local install_file
  for install_file in "$OME_HOME"/modules/*/install.zsh(N); do
    source "$install_file"
  done

  ome_info "Install complete."
}

ome_cmd_update() {
  ome_info "Updating oh-my-environment..."

  # Update ome itself
  local output
  if output=$(git -C "$OME_HOME" pull --ff-only 2>&1); then
    if [[ "$output" != *"Already up to date"* ]]; then
      ome_info "oh-my-environment updated."
    else
      ome_info "oh-my-environment already up to date."
    fi
  else
    ome_warn "Failed to update ome: $output"
  fi

  # Update installed plugins
  local plugin_dir
  for plugin_dir in "$OME_HOME/.custom/plugins"/*(N/); do
    [[ -d "$plugin_dir/.git" ]] || continue
    local plugin_name="${plugin_dir:t}"
    if output=$(git -C "$plugin_dir" pull 2>&1); then
      if [[ "$output" != *"Already up to date"* ]]; then
        ome_info "Plugin updated: $plugin_name"
      fi
    else
      ome_warn "Failed to update plugin $plugin_name: $output"
    fi
  done

  # Re-install (re-symlink modules)
  ome_cmd_install

  ome_info "Update complete."
}

# --- Dispatch ---

ome_help() {
  cat <<'EOF'
ome — oh-my-environment tool manager

Usage: ome <command>

Commands:
  install   Symlink modules into $ZSH_CUSTOM and run module setup
  update    Pull latest ome and update all installed plugins

Config repo and plugins are managed by 'omc'.
EOF
}

case "${1:-}" in
  install)  ome_cmd_install ;;
  update)   ome_cmd_update ;;
  --help|-h|help|"")  ome_help ;;
  *)
    ome_error "Unknown command: $1"
    ome_help
    exit 1
    ;;
esac
