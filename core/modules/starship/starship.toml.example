# Starship prompt configuration
# Full reference: https://starship.rs/config/
#
# Copy this file to ~/.config/starship.toml and customize to your liking:
#   cp starship.toml.example ~/.config/starship.toml

# --- Prompt format ---
# Controls which modules appear and in what order.
# Remove or add modules as needed. Available modules:
# https://starship.rs/config/#prompt
#
# Minimal (git-focused):
# format = """
# $directory\
# $git_branch\
# $git_status\
# $character"""
#
# With language versions:
# format = """
# $directory\
# $git_branch\
# $git_status\
# $python\
# $nodejs\
# $java\
# $character"""

format = """
$directory\
$git_branch\
$git_status\
$character"""

# --- Directory ---
# How the current directory is displayed.
[directory]
truncation_length = 3       # show up to 3 parent dirs
truncate_to_repo = true     # truncate to repo root when inside a git repo
# style = "bold cyan"       # override directory color

# --- Git branch ---
[git_branch]
format = "[$branch]($style) "
style = "bold purple"
# truncation_length = 20    # truncate long branch names
# truncation_symbol = "…"

# --- Git status ---
# Shows indicators for modified, staged, untracked, etc.
[git_status]
format = '([$all_status$ahead_behind]($style) )'
style = "bold red"
# conflicted = "="
# ahead = "⇡${count}"
# behind = "⇣${count}"
# diverged = "⇕⇡${ahead_count}⇣${behind_count}"
# untracked = "?"
# stashed = "$"
# modified = "!"
# staged = "+"
# renamed = "»"
# deleted = "✘"

# --- Character ---
# The prompt symbol. Changes color based on last command's exit code.
[character]
success_symbol = "[❯](bold green)"
error_symbol = "[❯](bold red)"
# vimcmd_symbol = "[❮](bold green)"   # shown in vi normal mode

# --- Language modules (disabled by default in minimal format) ---
# Uncomment and add to format above to enable.

# [python]
# format = '[${symbol}${pyenv_prefix}(${version} )(\($virtualenv\) )]($style)'
# symbol = "🐍 "

# [nodejs]
# format = "[$symbol($version )]($style)"
# symbol = "⬢ "

# [java]
# format = "[$symbol($version )]($style)"
# symbol = "☕ "

# [rust]
# format = "[$symbol($version )]($style)"
# symbol = "🦀 "

# [golang]
# format = "[$symbol($version )]($style)"
# symbol = "🐹 "

# --- Other useful modules ---

# [cmd_duration]
# min_time = 2_000            # show duration for commands taking >2s
# format = "took [$duration]($style) "

# [battery]
# full_symbol = "🔋"
# charging_symbol = "⚡"
# discharging_symbol = "💀"
# [[battery.display]]
# threshold = 20
# style = "bold red"

# [time]
# disabled = false
# format = '[$time]($style) '
# time_format = "%H:%M"
